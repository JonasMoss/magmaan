{
  "version": 6,
  "cmakeMinimumRequired": { "major": 3, "minor": 28, "patch": 0 },
  "configurePresets": [
    {
      "name": "default",
      "displayName": "Default (Debug, portable toolchain)",
      "binaryDir": "${sourceDir}/build/default",
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_CXX_SCAN_FOR_MODULES": "OFF"
      }
    },
    {
      "name": "_local",
      "displayName": "Local toolchain mix-in (clang + ccache + mold)",
      "hidden": true,
      "inherits": "default",
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "clang++",
        "CMAKE_C_COMPILER_LAUNCHER": "ccache",
        "CMAKE_CXX_COMPILER_LAUNCHER": "ccache",
        "CMAKE_EXE_LINKER_FLAGS": "-fuse-ld=mold",
        "CMAKE_SHARED_LINKER_FLAGS": "-fuse-ld=mold"
      }
    },
    {
      "name": "fast",
      "displayName": "Fast local C++ loop (Debug, no sanitizers)",
      "inherits": "_local",
      "binaryDir": "${sourceDir}/build/fast",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_CXX_COMPILER": "clang++"
      }
    },
    {
      "name": "dev",
      "displayName": "Local dev (Debug + ASan/UBSan)",
      "inherits": "_local",
      "binaryDir": "${sourceDir}/build/dev",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "MAGMAAN_SANITIZER": "asan+ubsan",
        "CMAKE_CXX_COMPILER": "clang++"
      }
    },
    {
      "name": "coverage",
      "displayName": "Local coverage (Debug + LLVM source coverage)",
      "inherits": "_local",
      "binaryDir": "${sourceDir}/build/coverage",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++",
        "CMAKE_C_FLAGS_DEBUG": "-O0 -g -fprofile-instr-generate -fcoverage-mapping",
        "CMAKE_CXX_FLAGS_DEBUG": "-O0 -g -fprofile-instr-generate -fcoverage-mapping",
        "CMAKE_EXE_LINKER_FLAGS": "-fuse-ld=mold -fprofile-instr-generate -fcoverage-mapping",
        "CMAKE_SHARED_LINKER_FLAGS": "-fuse-ld=mold -fprofile-instr-generate -fcoverage-mapping"
      }
    },
    {
      "name": "opt",
      "displayName": "Local optimized (Release + native CPU)",
      "inherits": "_local",
      "binaryDir": "${sourceDir}/build/opt",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_CXX_COMPILER": "clang++",
        "CMAKE_CXX_FLAGS_RELEASE": "-O3 -DNDEBUG -march=native"
      }
    },
    {
      "name": "release",
      "displayName": "Portable Release (no local toolchain assumptions)",
      "inherits": "default",
      "binaryDir": "${sourceDir}/build/release",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Release" }
    },
    {
      "name": "asan",
      "inherits": "_local",
      "binaryDir": "${sourceDir}/build/asan",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "MAGMAAN_SANITIZER": "asan+ubsan",
        "CMAKE_CXX_COMPILER": "clang++"
      }
    },
    {
      "name": "ubsan",
      "inherits": "_local",
      "binaryDir": "${sourceDir}/build/ubsan",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "MAGMAAN_SANITIZER": "ubsan",
        "CMAKE_CXX_COMPILER": "clang++"
      }
    },
    {
      "name": "ceres",
      "displayName": "Optional optimizer optimized (Release + native CPU)",
      "inherits": "_local",
      "binaryDir": "${sourceDir}/build/ceres",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_CXX_COMPILER": "clang++",
        "CMAKE_CXX_FLAGS_RELEASE": "-O3 -DNDEBUG -march=native",
        "MAGMAAN_WITH_CERES": "ON"
      }
    },
    {
      "name": "ipopt",
      "displayName": "Optional IPOPT optimizer (Release + native CPU)",
      "inherits": "_local",
      "binaryDir": "${sourceDir}/build/ipopt",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_CXX_COMPILER": "clang++",
        "CMAKE_CXX_FLAGS_RELEASE": "-O3 -DNDEBUG -march=native",
        "MAGMAAN_WITH_IPOPT": "ON"
      }
    }
  ],
  "buildPresets": [
    { "name": "default", "configurePreset": "default" },
    { "name": "fast",    "configurePreset": "fast" },
    { "name": "dev",     "configurePreset": "dev" },
    { "name": "coverage", "configurePreset": "coverage" },
    { "name": "opt",     "configurePreset": "opt" },
    { "name": "release", "configurePreset": "release" },
    { "name": "asan",    "configurePreset": "asan" },
    { "name": "ubsan",   "configurePreset": "ubsan" },
    { "name": "ceres",   "configurePreset": "ceres" },
    { "name": "ipopt",   "configurePreset": "ipopt" }
  ],
  "testPresets": [
    {
      "name": "default",
      "configurePreset": "default",
      "output": { "outputOnFailure": true },
      "execution": { "noTestsAction": "error", "stopOnFailure": false }
    },
    { "name": "fast",    "inherits": "default", "configurePreset": "fast" },
    { "name": "dev",     "inherits": "default", "configurePreset": "dev" },
    { "name": "coverage", "inherits": "default", "configurePreset": "coverage" },
    { "name": "opt",     "inherits": "default", "configurePreset": "opt" },
    { "name": "release", "inherits": "default", "configurePreset": "release" },
    { "name": "asan",    "inherits": "default", "configurePreset": "asan" },
    { "name": "ubsan",   "inherits": "default", "configurePreset": "ubsan" },
    { "name": "ceres",   "inherits": "default", "configurePreset": "ceres" },
    { "name": "ipopt",   "inherits": "default", "configurePreset": "ipopt" }
  ]
}
