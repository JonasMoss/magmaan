(* ===========================================================================
   magmaan model syntax — v0 grammar
   ---------------------------------------------------------------------------
   Source of truth for the lexer + recursive-descent parser. Every production
   below corresponds 1:1 to a function in the C++ implementation; functions
   carry a `// production: <name>` back-reference comment so this file and
   the code can be cross-checked.

   Notation: W3C-style EBNF.
     A ::= B            definition
     A | B              alternation
     A B                concatenation
     A?  A*  A+         optional / zero-or-more / one-or-more
     ( ... )            grouping
     'literal'          terminal
     [a-z]              character class
     A - B              set difference
     /* ... */          comment

   v0 scope: see docs/grammar/grammar.md for what is intentionally rejected.
   ===========================================================================*)


(* === Top level ============================================================= *)

model               ::= statement_sep* statement (statement_sep+ statement)*
                        statement_sep*
statement_sep       ::= NEWLINE | ';'
statement           ::= block_header | formula | constraint | define_param

(* === Block headers =========================================================
   A `group:` / `level:` header on its own line opens a new block. lavaan's
   `lavParseModelString` treats the keyword + ':' + block index/label as a
   block boundary: every formula that follows lands in that block until the
   next header. `block` advances 1, 2, 3, … in header order. v1 supports the
   two-level `level:` axis (1 = within / L1, 2 = between / L2) over a shared
   observed variable set; `group:` headers and 3+ levels are reserved.
   The `:` is lexed as its own `Colon` punctuation token only in this header
   position (the lexer otherwise still rejects a lone ':'). *)
block_header        ::= block_keyword ':' ( num_lit | identifier | string_lit )
block_keyword       ::= 'group' | 'level' | 'block'


(* === Formulas ============================================================== *)

formula             ::= lhs_list operator NEWLINE* rhs_list
lhs_list            ::= identifier ('+' identifier)*       /* multi-LHS only meaningful for `~` */
operator            ::= measurement | composite | regression | covariance
                      | threshold | response_scale | rejected_operator
measurement         ::= '=~'
composite           ::= '<~'
regression          ::= '~'
covariance          ::= '~~'
threshold           ::= '|'
response_scale      ::= '~*~'

(* Intercept forms are recognized by the parser when `regression` is followed
   by an `intercept_rhs`. Bare `1` means a free intercept/mean; any other bare
   numeric literal means a fixed intercept/mean at that value. Modifier-on-1
   forms such as `label*1` and `0*1` preserve the modifier. We do NOT lex
   `~1` as a single token to keep tokenization context-free. *)
rhs_list            ::= intercept_rhs | rhs_term (rhs_sep rhs_term)*
rhs_sep             ::= '+'+                               /* repeated `+` accepted like lavaan */
intercept_rhs       ::= num_lit | modifier_chain '1'       /* only valid after `~` */

rhs_term            ::= modifier_chain identifier
                      | identifier
modifier_chain      ::= modifier modifier_sep (modifier modifier_sep)*
modifier_sep        ::= '*' | '?'                          /* '?' forces start-value interpretation */


(* === Modifiers ============================================================= *)

modifier            ::= modifier_atom | group_vec | start_call | equal_call
modifier_atom       ::= signed_num_lit | NA | identifier | string_lit
                      | parenthesized_label
signed_num_lit      ::= ('+' | '-')? num_lit
parenthesized_label ::= '(' NEWLINE* ( signed_num_lit | identifier | string_lit )
                        NEWLINE* ')'
group_vec           ::= 'c' '(' modifier_atom (',' modifier_atom)* ')'
start_call          ::= 'start' '(' signed_num_lit ')'
equal_call          ::= 'equal' '(' ( string_lit | identifier ) ')'


(* === Constraints =========================================================== *)

constraint          ::= expr constraint_op expr
constraint_op       ::= '==' | '<' | '>'
define_param        ::= identifier ':=' expr


(* === Expression sublanguage ================================================
   Used for both `:=` definitions and `==` / `<` / `>` constraints. The only
   function calls are the unary `exp` / `log`; an identifier followed by `(`
   is a function call, an identifier alone is a parameter reference.
   ============================================================================*)

expr                ::= term (('+' | '-') term)*
term                ::= factor (('*' | '/') factor)*
factor              ::= power
power               ::= unary ('^' power)?                 /* right-associative */
unary               ::= ('+' | '-') unary | primary
primary             ::= num_lit | function_call | identifier | '(' expr ')'
function_call       ::= ('exp' | 'log') '(' expr ')'


(* === Rejected operators ====================================================
   These tokenize as their own kinds so the parser can produce a precise
   `ParseError::Kind::UnsupportedOperator` with the offending span, rather
   than a generic "expected operator" message.
   ============================================================================*)

rejected_operator   ::= '|~'


(* === Lexical (terminals) ===================================================
   These are also documented with full character predicates in
   docs/grammar/lexer.md. The forms below are the normative grammar.
   ============================================================================*)

NEWLINE             ::= '\n' | '\r' '\n' | '\r'
WS                  ::= ' ' | '\t'                          /* between tokens; never significant */
comment             ::= ('#' | '!') (CHAR - NEWLINE)* (NEWLINE | EOF)

identifier          ::= id_start id_cont*
id_start            ::= [A-Za-z_.]
id_cont             ::= [A-Za-z0-9_.]

num_lit             ::= digit+ ('.' digit*)? exponent?
                      | '.' digit+ exponent?
exponent            ::= ('e' | 'E') ('+' | '-')? digit+
digit               ::= [0-9]

(* `NA` is not an identifier in lavaan's modifier evaluator. We tokenize it
   as a distinct keyword so the parser can detect it without a string compare. *)
NA                  ::= 'NA'

string_lit          ::= '"' (CHAR - ('"' | NEWLINE))* '"'

(* === End of v0 grammar ==================================================== *)
