build/
build-*/
CMakeFiles/
.cache/
compile_commands.json
.claude/

# Development-help materials: source mirrors + reference PDFs you read while
# developing. Ignored except the in-folder convention doc. See external/README.md.
# Uses external/* (not external/) so the README exception can re-include — a
# parent dir excluded by `external/` cannot have children re-included.
external/*
!external/README.md

# Local paper projects live here as independent nested git repositories.
# Shared convention and style docs are the exceptions that live in magmaan.
papers/*
!papers/AGENTS.md
!papers/STYLE.md
!papers/CLAUDE.md

# The real-data textbook-corpus is a private, optional dependency: third-party
# copyrighted datasets magmaan may not redistribute. Mount it at
# corpus/textbook-corpus/ but never commit it. Only the README is tracked.
# See corpus/README.md.
corpus/*
!corpus/README.md

# Private working notes (not for publication).
docs/research/human_notes/

*.o
*.obj
*.a
*.so
*.dylib
*.dll
*.exe
.vscode/
.idea/
*.swp
.DS_Store
.Rproj.user
.RData
.Rhistory
r-package/src/.magmaan-build-config

# Private rslurm/Slurm scratch (R scripts, binary .RData/.RDS, job artifacts).
dev/slurm/
