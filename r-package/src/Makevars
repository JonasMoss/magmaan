# Self-contained build: R compiles the vendored magmaan C++ core + PORT +
# QUADPACK in this src/ and links a system NLopt. No CMake, no prebuilt
# libmagmaan.a, no reach-up to ../../{src,include} — so the package installs on
# its own (remotes::install_github, a tarball, an HPC scp).
#
# The core/, magmaan/, and third_party/ trees are VENDORED by dev/vendor-cpp.sh
# (`just vendor`); every file there carries an @generated banner. Do NOT edit
# them — edit the canonical sources under <repo>/src + <repo>/include and
# re-vendor. The fast dev loop (`just r-dev`) uses dev/r-makevars-dev instead,
# which compiles only the Rcpp glue and links a prebuilt libmagmaan.a.
#
# Optimization flags are deliberately NOT set here: the package stays portable
# (R's default -O2). Crank them per-machine via R_MAKEVARS_USER, e.g. on Saga
# `R_MAKEVARS_USER=dev/saga/Makevars R CMD INSTALL r-package` for -O3 -march=native.

CXX_STD = CXX23

# NLopt resolution, in order of preference:
#   1. NLOPT_CFLAGS / NLOPT_LIBS from the environment (an HPC module or a custom
#      build — wins because of ?=).
#   2. A system NLopt via pkg-config.
#   3. The nloptr CRAN package: it bundles and self-builds NLopt, so no system
#      module is needed (ideal for HPC / Saga). nlopt.h comes from LinkingTo:
#      nloptr; its nloptr.so exports the nlopt_* C API, linked by full path +
#      rpath. nloptr is an Imports, so it is guaranteed installed.
#   4. A bare -lnlopt.
NLOPT_CFLAGS ?= $(shell pkg-config --cflags nlopt 2>/dev/null)
NLOPT_LIBS   ?= $(shell pkg-config --libs nlopt 2>/dev/null)
ifeq ($(strip $(NLOPT_LIBS)),)
  NLOPTR_SO := $(shell "$(R_HOME)/bin/Rscript" -e 'f <- list.files(system.file("libs", package="nloptr"), pattern="nloptr[.]so$$", full.names=TRUE); cat(f[1])' 2>/dev/null)
  ifneq ($(strip $(NLOPTR_SO)),)
    NLOPT_LIBS := $(NLOPTR_SO) -Wl,-rpath,$(dir $(NLOPTR_SO))
  else
    NLOPT_LIBS := -lnlopt
  endif
endif

# -I.                          qualified public headers, #include "magmaan/..."
# -Icore                       private impl headers, #include "detail_*.hpp"
# -Ithird_party/port/cport     f2c.h for the vendored PORT translation units
# -Ithird_party/quadpack       f2c.h for the vendored QUADPACK translation units
# Eigen comes from RcppEigen (LinkingTo); the Eigen flags match the C++ library.
PKG_CPPFLAGS = -I. -Icore -Ithird_party/port/cport -Ithird_party/quadpack \
  -DMAGMAAN_WITH_PORT -DEIGEN_NO_EXCEPTIONS -DEIGEN_MAX_ALIGN_BYTES=64 \
  $(NLOPT_CFLAGS)

# The vendored f2c-translated C is not warning-clean and predates C23's
# "()-means-(void)" rule (reverse-communication callbacks declared K&R-style), so
# pin it to gnu11 and silence its warnings — without muting the C++ warnings.
PKG_CFLAGS = -w -std=gnu11

PKG_LIBS = $(NLOPT_LIBS)

# R only auto-compiles top-level src/*.{c,cpp}; the vendored core/ + third_party/
# trees live in subdirectories, so enumerate the objects explicitly.
SOURCES_CPP = $(wildcard *.cpp core/*.cpp core/*/*.cpp core/*/*/*.cpp core/*/*/*/*.cpp)
SOURCES_C   = $(wildcard third_party/port/*.c third_party/port/cport/*.c third_party/quadpack/*.c)
OBJECTS = $(SOURCES_CPP:.cpp=.o) $(SOURCES_C:.c=.o)
