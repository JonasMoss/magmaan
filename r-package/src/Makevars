# Repo root = two levels up from this Makevars. During an R build the cwd is
# <repo>/r-package/src, so $(CURDIR)/../.. is the magmaan repo root.
MAGMAAN_ROOT := $(abspath $(CURDIR)/../..)
MAGMAAN_PRESET ?= opt
MAGMAAN_BUILD ?= $(MAGMAAN_ROOT)/build/$(MAGMAAN_PRESET)
MAGMAAN_LIB  := $(MAGMAAN_BUILD)/libmagmaan.a
MAGMAAN_PORT_LIB := $(MAGMAAN_BUILD)/libport.a
MAGMAAN_NLOPT_LIB := $(MAGMAAN_BUILD)/_deps/nlopt-build/libnlopt.a
MAGMAAN_CMAKE_CACHE := $(MAGMAAN_BUILD)/CMakeCache.txt
MAGMAAN_NLOPT_CACHE_ON := $(shell if test -r "$(MAGMAAN_CMAKE_CACHE)" && grep -q '^MAGMAAN_WITH_NLOPT:BOOL=ON' "$(MAGMAAN_CMAKE_CACHE)"; then printf 1; else printf 0; fi)
MAGMAAN_WITH_CERES_R ?= 0
MAGMAAN_WITH_NLOPT_R ?= $(MAGMAAN_NLOPT_CACHE_ON)
MAGMAAN_CONFIG_STAMP := .magmaan-build-config
R_GLUE_HEADERS := $(wildcard *.hpp)

CXX_STD       = CXX23
PKG_CPPFLAGS  = -I$(MAGMAAN_ROOT)/include -DEIGEN_MAX_ALIGN_BYTES=64
override CXXFLAGS += -O3 -DNDEBUG -march=native
# libmagmaan.a links PRIVATEly against libport.a in the C++ CMake build, so
# the static archive carries unresolved PORT symbols (drmngb_, drn2gb_, ...).
# The R shared object must pull in libport.a explicitly or it fails to load
# with `undefined symbol: drmngb_`. Same pattern Ceres / NLopt already use.
PKG_LIBS      = $(MAGMAAN_LIB) $(MAGMAAN_PORT_LIB)

ifeq ($(MAGMAAN_WITH_CERES_R),1)
PKG_CPPFLAGS += -DMAGMAAN_WITH_CERES
PKG_LIBS     += -lceres -lglog -lgflags
endif

# When libmagmaan.a is built with the optional NLopt backend, the archive
# carries unresolved nlopt_* symbols; the final R shared object must also
# link NLopt or it fails to load (undefined symbol: nlopt_get_numevals).
# magmaan fetches NLopt as a static lib inside the CMake build tree, so we
# prefer that archive and fall back to a system -lnlopt. By default this
# follows MAGMAAN_WITH_NLOPT in the selected build's CMake cache, but explicit
# MAGMAAN_WITH_NLOPT_R=0/1 still wins for unusual local builds.
ifeq ($(MAGMAAN_WITH_NLOPT_R),1)
PKG_CPPFLAGS += -DMAGMAAN_WITH_NLOPT
PKG_LIBS     += $(if $(wildcard $(MAGMAAN_NLOPT_LIB)),$(MAGMAAN_NLOPT_LIB),-lnlopt)
endif

# Make sure libmagmaan.a is current before linking the
# R glue. Incremental: a no-op (~1s) when nothing changed in the C++ tree.
$(SHLIB): magmaan_lib

.PHONY: magmaan_lib FORCE
magmaan_lib:
	@cmake --build "$(MAGMAAN_BUILD)" --target magmaan 2>/dev/null || \
	  ( cd "$(MAGMAAN_ROOT)" && cmake --preset "$(MAGMAAN_PRESET)" && cmake --build --preset "$(MAGMAAN_PRESET)" --target magmaan )

$(MAGMAAN_CONFIG_STAMP): FORCE
	@tmp="$@.tmp"; \
	printf '%s\n' "MAGMAAN_PRESET=$(MAGMAAN_PRESET)" "MAGMAAN_BUILD=$(MAGMAAN_BUILD)" "MAGMAAN_WITH_CERES_R=$(MAGMAAN_WITH_CERES_R)" "MAGMAAN_WITH_NLOPT_R=$(MAGMAAN_WITH_NLOPT_R)" > "$$tmp"; \
	if test -r "$@" && cmp -s "$$tmp" "$@"; then rm "$$tmp"; else mv "$$tmp" "$@"; fi

# R's auto-generated package Makefile only tracks .cpp -> .o; it has no idea
# the R-glue objects also depend on the magmaan headers libmagmaan.a was built
# from. So a header change in the C++ tree re-links libmagmaan.a (above) but
# would otherwise leave a stale .o linked against the now-incompatible archive
# (-> "undefined symbol" at load time, the exact footgun this guards). Make the
# package objects depend on libmagmaan.a: when `magmaan_lib` re-links it, they
# rebuild. Cheap (a handful of small TUs); a no-op when nothing changed.
$(OBJECTS): $(MAGMAAN_LIB) $(MAGMAAN_CONFIG_STAMP) $(R_GLUE_HEADERS)
